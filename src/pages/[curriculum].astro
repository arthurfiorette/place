---
import { getCollection } from 'astro:content';
import Section from '../components/section.astro';
import Document from '../layouts/document.astro';

export async function getStaticPaths() {
  const cvs = await getCollection('curriculum');

  return cvs.map((cv) => ({
    params: { curriculum: cv.data.id },
    props: {
      ...cv,
      cvs
    }
  }));
}

const cv = Astro.props;
---

<Document light header={false} footer={false} class='gap-4'>
  <div class='print:hidden absolute top-3.5 text-sm'>
    <div>
      {cv.cvs
        .filter((cv2) => cv2.id !== cv.id)
        .map((cv2) => (
          <a class='no-underline hover:underline' href={`/${cv2.data.id}`}>
            {cv2.data.lang}
          </a>
        ))}
      <div class='mx-[1vw] inline-block' />
      <a href={`/${cv.data.id}.pdf`} class='no-underline hover:underline'>
        📄 Download as PDF
      </a>
      <div class='mx-[1vw] inline-block' />
      <a href="/" class='no-underline hover:underline'>
        🏠 Homepage
      </a>
    </div>
  </div>

  <Section class='[&:not(print)]:mt-5 cv'>
    <small class='block text-right text-sm text-neutral-600'>{cv.data.title}</small>
    <h1 class='mb-0 text-center text-5xl max-[650px]:text-4xl'>{cv.data.name}</h1>
    <small class='text-center block text-base'>
      {cv.data.phone} | <a href={`mailto:${cv.data.email}`}>{cv.data.email}</a>
    </small>

    <p class='text-base mt-1 ml-5 text-right'>
      <a class='text-base' href='https://arthur.place' target='_blank' rel='noopener noreferrer'>
        arthur.place
      </a>
      <br />
      <a
        class='text-base'
        href='https://linkedin.com/in/arthurfiorette'
        target='_blank'
        rel='noopener noreferrer'>
        linkedin.com/in/arthurfiorette
      </a>
      <br />
      <small class="text-red-500">{cv.data.month}</small>
    </p>
  </Section>

  <Section>
    {cv.data.about.map((a) => (
      <p set:html={a} class='text-base my-1' />
    ))}
  </Section>

  <Section>
    <h2 class='mb-0 text-2xl'>{cv.data.educationName}</h2>

    <ul class='flex flex-col gap-2'>
      {cv.data.education.map((education) => (
        <li class='py-1 m-0'>
          <h4 class='m-0 text-base font-mono text-neutral-600'>{education.date}</h4>
          <div class='m-0 text-base font-medium' set:html={education.title} />
          <div class='text-sm'>{education.institution}</div>
        </li>
      ))}
    </ul>
  </Section>

  <Section class='m-0 p-0'>
    <h2 class='mb-0 p-0 text-2xl'>{cv.data.experienceName}</h2>

    <ul class='m-0 p-0'>
      {cv.data.experiences.map((experience) => (
        <li class='flex gap-5 mt-3 max-[650px]:flex-col max-[650px]:gap-1'>
          <div class='text-right whitespace-nowrap max-[650px]:text-left'>
            <b class='block text-base'>{experience.start} </b>
            <b class='block text-base'>{experience.end}</b>
            <small class='font-mono text-neutral-600'>{experience.type}</small>
          </div>

          <div class='flex flex-col gap-1.5'>
            {/* biome-ignore lint/a11y/useHeadingContent: broken */}
            <h4 class='m-0 align-center text-lg' set:html={experience.title} />
            <div>
              {experience.about.map((c) => (
                <p class='m-0 text-base' set:html={c} />
              ))}
            </div>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section>
    <h2 class='m-0 p-0 text-2xl'>{cv.data.ossTitle}</h2>

    <div>
      {cv.data.oss.map((c) => (
        <p class='text-base my-0 py-0 pt-2' set:html={c} />
      ))}
    </div>
  </Section>
</Document>
