---
import MainNav from '../components/main-nav.astro';
import PostCard from '../components/post-card.astro';
import Section from '../components/section.astro';
import Document from '../layouts/document.astro';
import { posts } from '../util/posts/get-posts';
---

<Document header={false}>
  <Section class='flex items-start gap-5'>
    <div class='w-full'>
      <h1 class='text-4xl mt-0 mb-2'>Posts</h1>
      <p class='text-neutral-300 mt-0 mb-6'>
        Backend engineering notes about TypeScript, architecture and open source.
      </p>
      {
        !!posts.length && (
          <ol class='p-0! m-0! list-none w-full space-y-3'>
            {posts.map((post) => (
              <li
                class:list={[
                  'transition-all hover:bg-neutral-800/70 border border-neutral-800/70 hover:border-neutral-600 p-4 rounded-lg w-full block',
                  (post.data.published === false || post.data.published === 'preview') &&
                    '!bg-amber-900/25 !border-amber-700/40'
                ]}>
                <PostCard minimalistic data={post} />
              </li>
            ))}
          </ol>
        )
      }
    </div>
    <MainNav />
  </Section>
</Document>
