---
import type { CollectionEntry } from 'astro:content';
import { getReadTime } from '../util/read-time';
import MinRead from './min-read.astro';
import Time from './time.astro';

interface Props {
  data: CollectionEntry<'blog'>;
  minimalistic?: boolean;
}

const {
  data: { data: post, id, body },
  minimalistic = false
} = Astro.props;
---

<a
  href={`/${id}`}
  title={post.description}
  class:list={[
    'no-underline group p-4 block w-full',
    minimalistic && 'flex! flex-col! justify-start! p-2'
  ]}>
  <small class='font-normal text-sm text-neutral-400 mb-3 block'>
    <Time datetime={post.date} />
    <MinRead minRead={getReadTime(body!)} />
  </small>
  <h2
    class:list={[
      'font-semibold text-2xl text-center mt-0 group-hover:text-cream-light',
      minimalistic && 'text-left!'
    ]}>
    {post.title}
  </h2>
  <p class='mb-0 font-normal text-lg text-neutral-300'>{post.description}</p>
</a>
